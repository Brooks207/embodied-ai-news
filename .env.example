# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Twitter / X API v2 ───────────────────────────────────────
# 申请地址: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=

# ── YouTube Data API v3 ──────────────────────────────────────
# 申请地址: https://console.cloud.google.com/
YOUTUBE_API_KEY=

# ── Weibo Cookie ─────────────────────────────────────────────
# 从浏览器 DevTools -> Network -> 复制 Cookie header 值
WEIBO_COOKIE=

# ── 飞书 Bitable (多维表格) ────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_TABLE_ID=

# ── 存储后端选择 ──────────────────────────────────────────────
# feishu | excel | both
STORAGE_BACKEND=feishu

# ── 本地路径 ──────────────────────────────────────────────────
DB_PATH=eai_news/data/eai_news.db
EXCEL_PATH=eai_news/data/eai_news.xlsx

# ── 筛选阈值 ──────────────────────────────────────────────────
MIN_RELEVANCE_SCORE=5.0

# ── 调度配置 ──────────────────────────────────────────────────
COLLECT_INTERVAL_HOURS=2
DAILY_PUBLISH_HOUR=8
TRACKER_HOUR=23
